# ==============================================================================
# Environment variables — copy to .env.local and fill in.
# Never commit real secrets to git.
# ==============================================================================

# -------- Application --------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------- Database (Neon) --------
# Get this from https://console.neon.tech/ — use the pooled connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/scheduler?sslmode=require"
# Direct (non-pooled) connection for migrations
DATABASE_URL_UNPOOLED="postgresql://user:password@host.neon.tech/scheduler?sslmode=require"

# -------- Auth (Clerk) --------
# Get these from https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# -------- Scheduling engine --------
ENGINE_URL="http://localhost:8000"
# Shared secret for HMAC signing of callbacks from engine -> web
ENGINE_HMAC_SECRET="generate-a-random-32-byte-hex-string"

# -------- Error tracking (Sentry) --------
# Get these from https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# -------- Rate limiting (Upstash Redis) --------
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
