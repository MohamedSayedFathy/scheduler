{
  "extends": "@scheduler/config/typescript/next",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "drizzle.config.ts",
    "next.config.ts",
    "tailwind.config.ts",
    "postcss.config.mjs",
    "vitest.config.ts",
    "playwright.config.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": ["node_modules", ".next", "coverage", "playwright-report"]
}
